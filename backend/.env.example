ENVIRONMENT=development

# Postgres (matches docker-compose defaults — change if running your own DB)
DATABASE_URL=postgresql+asyncpg://nexora:nexora@localhost:5432/nexora

# Generate a real secret for production: `openssl rand -hex 32`
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CORS_ORIGINS=["http://localhost:5173"]

# Leave any of these blank to keep that integration in mock/demo mode.
OPENAI_API_KEY=
STRIPE_API_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
